# Wallet that signs fills. Required. Read from env, never logged.
PRIVATE_KEY=your_wallet_private_key_here

# Network: "testnet" (default) or "mainnet". Uncomment for a mainnet demo.
# PHAROS_NETWORK=mainnet

# RPC endpoint. OPTIONAL — a sane default is built in PER NETWORK:
#   testnet -> https://testnet.dplabs-internal.com
#   mainnet -> https://infra.originstake.com/pharos/evm
# Leave this unset to use the right default for the selected network. Only set
# it to override (e.g. if the default is blocked or slow). NOTE: if you set it,
# it applies to WHATEVER network is selected — don't pin a testnet URL here and
# then switch to mainnet.
# RPC_URL=

# Where orders persist. Optional.
ORDERS_FILE=./orders.json
